      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "id": 5,
      "targets": [{"expr": "sum by (model) (increase(llm_api_calls_total[1h]))", "legendFormat": "{{model}}", "refId": "A"}],
