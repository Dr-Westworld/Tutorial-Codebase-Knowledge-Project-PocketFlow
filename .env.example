# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0
PYTHONUNBUFFERED=1

# GitHub API Configuration (Optional)
# Get your token at: https://github.com/settings/tokens
# Required for: Processing public GitHub repositories
# Optional for: Local directory processing only
GITHUB_TOKEN=your_github_token_here

# Server Configuration
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000

# LLM Configuration (from main.py)
# MAX_ABSTRACTIONS=10
# DISABLE_CACHE=false

# Output Configuration
# OUTPUT_DIR=/app/output
# UPLOAD_DIR=/app/uploads
